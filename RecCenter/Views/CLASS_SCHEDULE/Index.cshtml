@model IEnumerable<RecCenter.CLASS_SCHEDULE>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Day_Of_Week)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Start_Time)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.End_Time)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Start_Date)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.End_Date)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Created_Date)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.CLASS.Class_Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FACILITY.Facility_Name)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Day_Of_Week)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Start_Time)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.End_Time)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Start_Date)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.End_Date)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Created_Date)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.CLASS.Class_Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.FACILITY.Facility_Name)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.Schedule_ID }) |
            @Html.ActionLink("Details", "Details", new { id=item.Schedule_ID }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.Schedule_ID })
        </td>
    </tr>
}

</table>
