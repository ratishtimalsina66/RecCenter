<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - RecCenter</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <div class="rec-app-shell">
        <header class="rec-header">
            <nav class="navbar navbar-inverse navbar-fixed-top rec-navbar">
                <div class="container">
                    <div class="navbar-header">
                        <button type="button"
                                class="navbar-toggle"
                                data-toggle="collapse"
                                data-target=".navbar-collapse">
                            <span class="icon-bar"></span>
                            <span class="icon-bar"></span>
                            <span class="icon-bar"></span>
                        </button>

                        @Html.ActionLink(
                            "RecCenter",
                            "Index",
                            "Home",
                            new { area = "" },
                            new { @class = "navbar-brand rec-brand" }
                        )
                    </div>

                    <div class="navbar-collapse collapse">
                        <ul class="nav navbar-nav rec-nav-links">
                            <li>@Html.ActionLink("Home", "Index", "Home")</li>
                            <li>@Html.ActionLink("About", "About", "Home")</li>
                            <li>@Html.ActionLink("Members", "Index", "Members")</li>
                            <li>@Html.ActionLink("Contact", "Contact", "Home")</li>

                            @* Later you can swap these to MEMBERs / FACILITies / CLASSes / EQUIPMENTs controllers *@
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main class="rec-main">
            <div class="container rec-body-container">
                @* Optional page header – shown when a view defines @section PageHeader *@
                @RenderSection("PageHeader", required: false)

                @RenderBody()

                <footer class="rec-footer">
                    <p class="footer-title">RecCenter Management System</p>
                    <p class="footer-meta">
                        &copy; @DateTime.Now.Year • Built by Ratish Timalsina
                    </p>
                </footer>
            </div>
        </main>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
